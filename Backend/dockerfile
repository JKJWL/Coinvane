FROM node:20-alpine
WORKDIR /app
# python3/make/g++: node-gyp for a couple of native deps at install time.
# mdbtools: reads tables out of unencrypted Jet databases — used on the
#   output of sunriise once it strips the .mny encryption.
# openjdk17-jre-headless: needed at runtime to invoke the sunriise jar.
#   NOTE: sunriise is optional. If vendor/sunriise.jar is not present at
#   build time, MNY import will still handle unencrypted .mny files via
#   mdbtools alone, and return a clear error on encrypted ones.
RUN apk add --no-cache python3 make g++ mdbtools openjdk17-jre-headless \
  && ln -sf python3 /usr/bin/python
COPY package*.json ./
RUN npm install --omit=dev
COPY src ./src
# Optional: copy the sunriise fat jar if the operator produced one via
# `scripts/build-sunriise.sh`. Wildcarded so the COPY is a no-op when
# vendor/sunriise.jar is absent — the Dockerfile still builds cleanly
# and the runtime code handles the missing-jar case with a helpful
# error rather than crashing.
COPY vendor/ /opt/vendor/
RUN if [ -f /opt/vendor/sunriise.jar ]; then \
      mv /opt/vendor/sunriise.jar /opt/sunriise.jar; \
    fi \
  && rm -rf /opt/vendor
ENV SUNRIISE_JAR=/opt/sunriise.jar
EXPOSE 4000
CMD ["node", "src/server.js"]