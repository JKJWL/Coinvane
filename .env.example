# Database
DB_ROOT_PASSWORD=
DB_NAME=ledger
DB_USER=ledger
DB_PASSWORD=
# Auth & encryption (generate with: openssl rand -hex 64 / openssl rand -hex 32)
JWT_SECRET=
ENCRYPTION_KEY=

# Google Sign-In (the SAME value goes in both vars — backend verifies, frontend renders the button)
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=

# ───────────────────────────────────────────────────────────────────
# Email allowlist — CRITICAL for public deployments.
# Comma-separated list of Google emails that are allowed to sign in.
# Any other Google account is rejected with HTTP 403.
# Leave empty to disable the allowlist (NOT recommended for public hosting).
ALLOWED_EMAILS=
# ───────────────────────────────────────────────────────────────────

# Plaid
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=production
PLAID_REDIRECT_URI=
PLAID_WEBHOOK_URL=

# First Google sign-in automatically becomes admin; no INITIAL_USER vars needed.

# App URL (used in emails)
APP_URL=
CORS_ORIGIN=

# Signup mode: "invite" (default), "open", or "closed"
SIGNUP_MODE=invite

# ───────────────────────────────────────────────────────────────────
# Email subsystem master switch.
#   disabled (default) — no emails sent; in-app notifications still work.
#   enabled            — actually sends mail via the SMTP config below.
# Keep disabled until you've configured + tested SMTP. The UI greys out
# the Email Notifs toggle when this is disabled and shows a warning.
EMAIL_CONFIG=disabled
# ───────────────────────────────────────────────────────────────────

# SMTP (only used when EMAIL_CONFIG=enabled)
# Leave SMTP_HOST blank to log emails to console even when enabled.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Ledger <noreply@example.com>